JWT_SECRET=

RESEND_API_KEY=
RESEND_FROM=

DB_TYPE=postgres
DB_USERNAME=postgres
DB_PASSWORD=condevPostgres
DB_DATABASE=postgres
DB_AUTOLOAD=true
DB_SYNC=true

POSTGRES_PORT=5432
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

CADDY_HTTP_HOST_PORT=80
CADDY_HTTP_CONTAINER_PORT=80
CADDY_HTTPS_HOST_PORT=443
CADDY_DSN_MAX_BODY_SIZE=10MB

CLICKHOUSE_USERNAME=lemonade
CLICKHOUSE_PASSWORD=condevClickhouse
CLICKHOUSE_DB=lemonade
CLICKHOUSE_MAX_HTTP_BODY_SIZE=10485760

EMAIL_SENDER=
EMAIL_SENDER_PASSWORD=
ALERT_EMAIL_FALLBACK=
APP_OWNER_EMAIL_CACHE_TTL_MS=300000
MAIL_ON=true
AUTH_REQUIRE_EMAIL_VERIFICATION=true

FRONTEND_URL=https://monitor.condevtools.com

SOURCEMAP_CACHE_MAX=200
SOURCEMAP_CACHE_TTL_MS=600000

DSN_BODY_LIMIT=10MB

# Kafka
KAFKA_EXTERNAL_PORT=9094
KAFKA_BROKERS=condev-monitor-kafka:9092
KAFKA_CLIENT_ID=condev-monitor
KAFKA_CONSUMER_GROUP=monitor-clickhouse-writer-v1
INGEST_MODE=kafka
KAFKA_ENABLED=true
KAFKA_FALLBACK_TO_CLICKHOUSE=true

# Inbound filter
INBOUND_MAX_PAYLOAD_BYTES=524288
INBOUND_UA_BLACKLIST=MSIE 9,MSIE 10,Trident/5.0,Trident/6.0
INBOUND_RELEASE_BLACKLIST=

# Rate limiter
RATE_LIMIT_EVENTS_PER_SEC=100
RATE_LIMIT_BURST=100
RATE_LIMIT_MAX_APPS=5000

# Embedding
EMBEDDING_MODEL_ID=Xenova/all-MiniLM-L6-v2
ISSUE_EMBEDDING_HIGH_THRESHOLD=0.92
ISSUE_EMBEDDING_LOW_THRESHOLD=0.85
ISSUE_TFIDF_THRESHOLD=0.80

# LLM (offline batch processing)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
