{
    "name": "@condev-monitor/nextjs",
    "version": "0.1.0",
    "main": "build/cjs/index.js",
    "module": "build/esm/index.mjs",
    "types": "build/types/index.d.ts",
    "files": [
        "build"
    ],
    "sideEffects": false,
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "types": "./build/types/index.d.ts",
                "default": "./build/esm/index.mjs"
            },
            "require": {
                "types": "./build/types/index.d.ts",
                "default": "./build/cjs/index.js"
            }
        },
        "./client": {
            "import": {
                "types": "./build/types/client.d.ts",
                "default": "./build/esm/client.mjs"
            },
            "require": {
                "types": "./build/types/client.d.ts",
                "default": "./build/cjs/client.js"
            }
        },
        "./chat": {
            "import": {
                "types": "./build/types/chat.d.ts",
                "default": "./build/esm/chat.mjs"
            },
            "require": {
                "types": "./build/types/chat.d.ts",
                "default": "./build/cjs/chat.js"
            }
        },
        "./server": {
            "import": {
                "types": "./build/types/server.d.ts",
                "default": "./build/esm/server.mjs"
            },
            "require": {
                "types": "./build/types/server.d.ts",
                "default": "./build/cjs/server.js"
            }
        }
    },
    "scripts": {
        "clean": "rimraf build",
        "build": "pnpm clean && pnpm build:transpile && pnpm build:types",
        "build:transpile": "tsup",
        "build:types": "tsc -p tsconfig.types.json"
    },
    "dependencies": {
        "@condev-monitor/monitor-sdk-ai": "workspace:*",
        "@condev-monitor/monitor-sdk-core": "workspace:*",
        "@condev-monitor/react": "workspace:*"
    },
    "peerDependencies": {
        "@opentelemetry/api": ">=1.9.0",
        "@opentelemetry/sdk-trace-base": ">=1.0.0",
        "ai": ">=6.0.0",
        "next": ">=15.3.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "@opentelemetry/api": {
            "optional": true
        },
        "@opentelemetry/sdk-trace-base": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "ai": "^6.0.116"
    }
}
