{
    "name": "@condev-monitor/react",
    "version": "0.1.0",
    "main": "build/cjs/index.js",
    "module": "build/esm/index.mjs",
    "types": "build/types/index.d.ts",
    "files": [
        "build"
    ],
    "sideEffects": false,
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "types": "./build/types/index.d.ts",
                "default": "./build/esm/index.mjs"
            },
            "require": {
                "types": "./build/types/index.d.ts",
                "default": "./build/cjs/index.js"
            }
        }
    },
    "scripts": {
        "clean": "rimraf build",
        "build": "pnpm clean && pnpm build:transpile && pnpm build:types",
        "build:transpile": "tsup",
        "build:types": "tsc -p tsconfig.types.json"
    },
    "dependencies": {
        "@condev-monitor/monitor-sdk-browser": "workspace:*",
        "@condev-monitor/monitor-sdk-core": "workspace:*"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0"
    }
}
