{
    "name": "@condev-monitor/monitor-sdk-ai",
    "version": "0.1.0",
    "main": "build/cjs/index.js",
    "module": "build/esm/index.mjs",
    "types": "build/types/index.d.ts",
    "files": [
        "build"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "types": "./build/types/index.d.ts",
                "default": "./build/esm/index.mjs"
            },
            "require": {
                "types": "./build/types/index.d.ts",
                "default": "./build/cjs/index.js"
            }
        },
        "./langchain": {
            "import": {
                "types": "./build/types/callbacks/langchain.d.ts",
                "default": "./build/esm/callbacks/langchain.mjs"
            },
            "require": {
                "types": "./build/types/callbacks/langchain.d.ts",
                "default": "./build/cjs/callbacks/langchain.js"
            }
        }
    },
    "scripts": {
        "build:watch": "pnpm build:watch:transpile & pnpm build:watch:types",
        "build:watch:transpile": "tsup --watch",
        "build:watch:types": "tsc -p tsconfig.types.json --watch",
        "clean": "rimraf build",
        "build": "pnpm clean && pnpm build:transpile && pnpm build:types",
        "build:transpile": "tsup",
        "build:types": "tsc -p tsconfig.types.json"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "AI SDK monitoring adapters for condev-monitor (Vercel AI, OpenAI, Anthropic, etc.)",
    "dependencies": {
        "@condev-monitor/monitor-sdk-core": "workspace:*"
    },
    "peerDependencies": {
        "@langchain/core": ">=0.2.0",
        "@opentelemetry/api": ">=1.0.0",
        "@opentelemetry/sdk-trace-base": ">=1.0.0"
    },
    "peerDependenciesMeta": {
        "@langchain/core": {
            "optional": true
        },
        "@opentelemetry/api": {
            "optional": true
        },
        "@opentelemetry/sdk-trace-base": {
            "optional": true
        }
    },
    "devDependencies": {
        "@langchain/core": "^1.1.36"
    }
}
