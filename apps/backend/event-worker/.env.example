PORT=8083

# Kafka Consumer
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=condev-monitor-worker
KAFKA_CONSUMER_GROUP=monitor-clickhouse-writer-v1
KAFKA_EVENTS_TOPIC=monitor.sdk.events.v1
KAFKA_REPLAYS_TOPIC=monitor.sdk.replays.v1
KAFKA_DLQ_TOPIC=monitor.sdk.dlq.v1
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=3000

# Multi-Lane Batch Strategy
# Critical lane (error/whitescreen) — low latency, more retries
CRITICAL_BATCH_SIZE=10
CRITICAL_BATCH_MAX_WAIT_MS=100
CRITICAL_MAX_RETRIES=8
CRITICAL_BACKOFF_CAP_MS=5000

# Normal lane (performance/webvital/custom/ai_streaming) — high throughput batching
NORMAL_BATCH_SIZE=500
NORMAL_BATCH_MAX_WAIT_MS=1000
NORMAL_MAX_RETRIES=5
NORMAL_BACKOFF_CAP_MS=10000

# Bulk lane (replay) — large payloads, small batches
BULK_BATCH_SIZE=50
BULK_BATCH_MAX_WAIT_MS=2000
BULK_MAX_RETRIES=5
BULK_BACKOFF_CAP_MS=10000

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=lemonade
CLICKHOUSE_PASSWORD=condevClickhouse
